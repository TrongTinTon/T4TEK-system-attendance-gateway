<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ==========================================
             ACTION: Máy chủ Mail Đến (Incoming)
             ========================================== -->
        <record id="action_fetchmail_server_admin_center" model="ir.actions.act_window">
            <field name="name">Máy Chủ Mail Đến</field>
            <field name="res_model">fetchmail.server</field>
            <field name="view_mode">list,form</field>
            <field name="context">{
                'default_name': 'Gmail Incoming',
                'default_server_type': 'imap',
                'default_server': 'imap.gmail.com',
                'default_port': 993,
                'default_is_ssl': True,
            }</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Chưa có máy chủ mail đến nào được cấu hình
                </p>
                <p>
                    Thêm máy chủ IMAP hoặc POP3 để nhận email vào hệ thống Odoo.
                </p>
            </field>
        </record>

        <!-- ==========================================
             SEARCH VIEW: Fetchmail Server
             ========================================== -->
        <record id="view_fetchmail_server_search_admin_center" model="ir.ui.view">
            <field name="name">fetchmail.server.search.admin_center</field>
            <field name="model">fetchmail.server</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <search string="Tìm kiếm Máy Chủ Mail Đến">
                    <field name="name" string="Tên máy chủ"/>
                    <field name="user" string="Tên đăng nhập"/>
                    <filter string="IMAP" name="imap" domain="[('server_type', '=', 'imap')]"/>
                    <filter string="POP" name="pop" domain="[('server_type', '=', 'pop')]"/>
                    <separator/>
                    <filter string="SSL/TLS" name="ssl" domain="[('is_ssl', '=', True)]"/>
                    <separator/>
                    <filter string="Đã xác nhận" name="confirmed" domain="[('state', '=', 'done')]"/>
                    <filter string="Chưa xác nhận" name="draft" domain="[('state', '=', 'draft')]"/>
                    <separator/>
                    <filter string="Đã lưu trữ" name="inactive" domain="[('active', '=', False)]"/>
                </search>
            </field>
        </record>

        <!-- ==========================================
             LIST VIEW: Fetchmail Server
             ========================================== -->
        <record id="view_fetchmail_server_tree_admin_center" model="ir.ui.view">
            <field name="name">fetchmail.server.list.admin_center</field>
            <field name="model">fetchmail.server</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <list string="Máy Chủ Mail Đến"
                      decoration-success="state == 'done'"
                      decoration-muted="not active">
                    <field name="name" string="Tên máy chủ"/>
                    <field name="server_type" string="Loại"/>
                    <field name="server" string="Địa chỉ server"/>
                    <field name="port" string="Cổng"/>
                    <field name="is_ssl" string="SSL/TLS"/>
                    <field name="user" string="Tên đăng nhập"/>
                    <field name="date" string="Lần fetch cuối"/>
                    <field name="state" string="Trạng thái" widget="badge"
                           decoration-success="state == 'done'"
                           decoration-info="state == 'draft'"/>
                    <field name="active" column_invisible="True"/>
                </list>
            </field>
        </record>

        <!-- ==========================================
             FORM VIEW: Fetchmail Server
             ========================================== -->
        <record id="view_fetchmail_server_form_admin_center" model="ir.ui.view">
            <field name="name">fetchmail.server.form.admin_center</field>
            <field name="model">fetchmail.server</field>
            <field name="priority">1</field>
            <field name="arch" type="xml">
                <form string="Máy Chủ Mail Đến">
                    <!-- Header: ẩn khi server_type = local -->
                    <header invisible="server_type == 'local'">
                        <button name="button_confirm_login" string="Kiểm Tra &amp; Xác Nhận"
                                type="object" class="btn-primary"
                                invisible="state != 'draft'"/>
                        <button name="button_confirm_login" string="Kiểm Tra Lại Kết Nối"
                                type="object" class="btn-secondary"
                                invisible="state != 'done'"/>
                        <button name="set_draft" string="Đặt Lại Trạng Thái"
                                type="object"
                                invisible="state != 'done'"/>
                    </header>
                    <sheet>
                        <div class="alert alert-success mt-2" role="alert" invisible="not is_imap_idle_running">
                            <i class="fa fa-refresh fa-spin me-1"/>
                            <strong>Đang lắng nghe real-time:</strong> Hệ thống sẽ tự động nhận email ngay khi có thư mới đến.
                        </div>
                        <field name="is_imap_idle_running" invisible="1"/>
                        <!-- Archive ribbon -->
                        <field name="active" invisible="1"/>
                        <widget name="web_ribbon" title="Đã lưu trữ"
                                bg_color="text-bg-danger"
                                invisible="active"/>

                        <!-- Tên + Loại giao thức -->
                        <group>
                            <group>
                                <field name="name" placeholder="Tên máy chủ mail đến..."
                                       string="Tên máy chủ"/>
                                <field name="server_type" widget="radio"
                                       string="Loại giao thức"
                                       readonly="state == 'done'"/>
                            </group>
                            <group>
                                <field name="date" string="Lần fetch cuối"
                                       invisible="not date"/>
                                <!-- Thông tin mô tả cho server_type (ví dụ Local Server) -->
                                <div class="text-muted fst-italic" colspan="2"
                                     invisible="not server_type_info">
                                    <field name="server_type_info"/>
                                </div>
                            </group>
                        </group>

                        <notebook>
                            <!-- ========== TAB 1: Server &amp; Đăng nhập ========== -->
                            <page string="Kết Nối &amp; Đăng Nhập" name="server_login">
                                <group>
                                    <!-- Thông tin Server: ẩn khi Local -->
                                    <group string="Thông Tin Kết Nối"
                                           invisible="server_type == 'local'">
                                        <field name="server"
                                               placeholder="imap.gmail.com"
                                               string="Địa chỉ Server"
                                               readonly="state == 'done'"
                                               required="server_type != 'local'"/>
                                        <field name="port"
                                               string="Cổng kết nối"
                                               required="1"
                                               readonly="state == 'done'"
                                               options="{'format': false}"/>
                                        <field name="is_ssl"
                                               string="Sử dụng SSL/TLS"/>
                                    </group>

                                    <!-- Thông tin Xác thực: ẩn khi Local -->
                                    <group string="Xác Thực"
                                           invisible="server_type == 'local'">
                                        <field name="user"
                                               string="Tên đăng nhập (Email)"
                                               readonly="state == 'done'"
                                               required="server_type != 'local'"/>
                                        <field name="password"
                                               string="Mật khẩu"
                                               password="True"
                                               readonly="state == 'done'"
                                               invisible="server_type not in ('imap', 'pop')"
                                               required="server_type in ('imap', 'pop')"/>
                                    </group>

                                    <!-- Hành động khi nhận mail -->
                                    <group string="Hành Động Khi Nhận Mail">
                                        <field name="object_id"
                                               string="Tạo bản ghi thuộc model"/>
                                    </group>

                                    <!-- Cấu hình Local Server: chỉ hiện khi Local -->
                                    <group string="Cấu Hình Local Server"
                                           invisible="server_type != 'local'">
                                        <field name="configuration"
                                               string="Hướng dẫn cấu hình"/>
                                        <field name="script" widget="url"
                                               string="Script"/>
                                    </group>
                                </group>
                            </page>

                            <!-- ========== TAB 2: Nâng cao ========== -->
                            <page string="Nâng Cao" name="advanced_options">
                                <group>
                                    <group string="Tuỳ Chọn Nâng Cao">
                                        <field name="priority"
                                               string="Độ ưu tiên"
                                               readonly="state == 'done'"/>
                                        <field name="attach"
                                               string="Lưu tệp đính kèm"/>
                                        <field name="original"
                                               string="Giữ bản gốc email"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Liên kết view với action -->
        <record id="action_fetchmail_server_admin_center_view_list" model="ir.actions.act_window.view">
            <field name="sequence" eval="10"/>
            <field name="view_mode">list</field>
            <field name="view_id" ref="view_fetchmail_server_tree_admin_center"/>
            <field name="act_window_id" ref="action_fetchmail_server_admin_center"/>
        </record>

        <record id="action_fetchmail_server_admin_center_view_form" model="ir.actions.act_window.view">
            <field name="sequence" eval="20"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_fetchmail_server_form_admin_center"/>
            <field name="act_window_id" ref="action_fetchmail_server_admin_center"/>
        </record>
    </data>
</odoo>
