<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- ===================== Cultural Level Category ===================== -->
    <record id="view_cultural_level_category_form" model="ir.ui.view">
        <field name="name">cultural.level.category.form</field>
        <field name="model">cultural.level.category</field>
        <field name="arch" type="xml">
            <form string="Trình Độ Văn Hóa">
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_cultural_level_category_list" model="ir.ui.view">
        <field name="name">cultural.level.category.list</field>
        <field name="model">cultural.level.category</field>
        <field name="arch" type="xml">
            <list string="Trình Độ Văn Hóa">
                <field name="code"/>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="action_cultural_level_category" model="ir.actions.act_window">
        <field name="name">Trình Độ Văn Hóa</field>
        <field name="res_model">cultural.level.category</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>