<?xml version="1.0" encoding="utf-8"?>
<odoo>

        <record id="view_department_form_t4tek" model="ir.ui.view">
            <field name="name">hr.department.form.t4tek</field>
            <field name="model">hr.department</field>
            <field name="priority">200</field>
            <field name="arch" type="xml">
                <form string="department">
                    <header>
                        <button name="action_add_employee_wizard" string="Thêm nhân viên" type="object" class="btn-primary" invisible="not id"/>
                    </header>
                    <field name="company_id" invisible="1"/>
                    <sheet>
                        <div class="oe_button_box" name="button_box" invisible="not id">
                            <button class="oe_stat_button" name="action_employee_from_department" type="object" icon="fa-users">
                                <field string="Employees" name="total_employee" widget="statinfo"/>
                            </button>
                            <button class="oe_stat_button" type="object" name="action_plan_from_department" icon="fa-list-ul">
                                <field string="Plans" name="plans_count" widget="statinfo"/>
                            </button>
                        </div>
                        <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                        <field name="active" invisible="1"/>
                        <div class="oe_title">
                            <h1>
                                <field name="name" placeholder="e.g. Sales"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <!-- <field name="valid_manager_ids" invisible="1"/> -->
                                <field name="manager_id" widget="many2one_avatar_employee"/>
                                <field name="parent_id"/>
                                <field name="company_id" options="{'no_create': True}" groups="base.group_multi_company"/>
                                <field name="color" widget="color_picker" string="Color"/>
                            </group>
                            <div invisible="not id or id and not child_ids and not parent_id">
                                <widget name="hr_department_chart"/>
                            </div>
                        </group>
                        <notebook>
                            <page name="rank" string="Chức vụ">
                                <field name="dept_job_ids" nolabel="1">
                                    <list editable="bottom">
                                        <field name="level"/>
                                        <field name="job_id"/>
                                        <field name="is_manager" string="Trưởng phòng"/>
                                        <field name="max_employee" string="Định biên" readonly="is_manager"/>
                                        <field name="no_of_employee" readonly="1" string="Thực tế"/>
                                        <field name="can_add_employee" column_invisible="True"/>
                                        <button name="action_show_employees" type="object" string="Nhân viên" icon="fa-users" title="Xem danh sách nhân viên"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="view_department_tree_t4tek" model="ir.ui.view">
            <field name="name">hr.department.list.t4tek</field>
            <field name="model">hr.department</field>
            <field name="arch" type="xml">
                <list string="Companies" multi_edit="1">
                    <field name="company_id" column_invisible="True"/>
                    <field name="name"/>
                    <field name="company_id" groups="base.group_multi_company" readonly="1"/>
                    <field name="manager_id" widget="many2one_avatar_employee"/>
                    <field name="total_employee" string="Employees"/>
                    <field name="parent_id"/>
                    <field name="color" widget="color_picker" string="Color"/>
                </list>
            </field>
        </record>

        <record id="view_department_filter_t4tek" model="ir.ui.view">
            <field name="name">hr.department.search.t4tek</field>
            <field name="model">hr.department</field>
            <field name="arch" type="xml">
                <search string="Departments">
                    <field name="name" string="Department"/>
                    <field name="manager_id" />
                    <filter string="Unread Messages" name="message_needaction" domain="[('message_needaction','=',True)]" groups="mail.group_mail_notification_type_inbox"/>
                    <separator/>
                    <filter string="Archived" name="inactive" domain="[('active','=',False)]"/>
                </search>
             </field>
        </record>

        <record id="hr_department_view_kanban_t4tek" model="ir.ui.view" >
            <field name="name">hr.department.kanban.t4tek</field>
            <field name="model">hr.department</field>
            <field name="arch" type="xml">
                <kanban highlight_color="color" class="o_hr_department_kanban o_kanban_small_column" can_open="0" sample="1">
                    <field name="active"/>
                    <templates>
                        <t t-name="menu" t-if="!selection_mode">
                            <div class="container">
                                <div class="row">
                                    <div class="col-6">
                                        <h5 role="menuitem" class="o_kanban_card_manage_title">
                                            <span>View</span>
                                        </h5>
                                        <div role="menuitem">
                                            <a name="action_employee_from_department" type="object">Employees</a>
                                        </div>
                                        <div role="menuitem">
                                            <a name="action_open_view_child_departments" type="object">Child departments</a>
                                        </div>
                                    </div>
                                    <div class="col-6 o_kanban_manage_reports">
                                        <h5 role="menuitem" class="o_kanban_card_manage_title">
                                            <span>Reporting</span>
                                        </h5>
                                    </div>
                                </div>
                                <div class="o_kanban_card_manage_settings row" groups="SEM.sem_department">
                                    <div t-if="widget.editable" role="menuitem" aria-haspopup="true" class="col-6">
                                        <field name="color" widget="kanban_color_picker"/>
                                    </div>
                                    <div class="col-6">
                                        <a t-if="widget.editable" role="menuitem" class="dropdown-item" type="open">Configuration</a>
                                        <a t-if="record.active.raw_value" role="menuitem" type="archive" class="dropdown-item">Archive</a>
                                        <a t-if="!record.active.raw_value" role="menuitem" type="unarchive" class="dropdown-item">Unarchive</a>
                                    </div>
                                </div>
                            </div>
                        </t>
                        <t t-name="card">
                            <a type="open"><field name="name" class="fw-bold fs-4 d-bolck ms-2"/></a>
                            <field name="manager_id" widget="many2one_avatar_employee" options="{'display_avatar_name': True}" readonly="1" class="text-muted ms-2"/>
                            <div class="small mt-1 ms-2" groups="base.group_multi_company">
                                <i class="fa fa-building-o" role="img" aria-label="Company" title="Company"/> <field name="company_id"/>
                            </div>
                            <div class="row g-0 mt-3 mb-2 ms-2" t-if="!selection_mode">
                                <div class="col-6">
                                    <button class="btn btn-primary" name="action_employee_from_department" type="object">
                                        <field name="total_employee"/> Employees
                                    </button>
                                </div>
                                <div name="kanban_primary_right" class="col-6">
                                    
                                </div>
                            </div>
                            <div name="kanban_card_lower_content" class="mt-auto" t-if="!selection_mode">
                                
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="view_hr_department_hierarchy" model="ir.ui.view">
            <field name="name">hr.department.view.hierarchy</field>
            <field name="model">hr.department</field>
            <field name="arch" type="xml">
                <hierarchy child_field="child_ids">
                    <field name="name"/>
                    <field name="manager_id"/>
                    <field name="color"/>
                    <templates>
                        <t t-name="hierarchy-box">
                            <div class="o_hierarchy_node_item d-flex flex-column align-items-center p-3 shadow-sm rounded border" 
                                 t-att-style="'min-width: 200px; color: #333333; background-color: ' + (['#ffffff', '#FF9C9C', '#F7C698', '#FDE388', '#BDD7F8', '#D9A8CC', '#F8D6C8', '#89E1DB', '#97A6F9', '#FF9ECC', '#B7EDBE', '#E6DBFC'][record.color.raw_value] || '#ffffff')">
                                <span class="fw-bold mb-1"><field name="name"/></span>
                                <span class="text-muted small"><field name="manager_id"/></span>
                            </div>
                        </t>
                    </templates>
                </hierarchy>
            </field>
        </record>

        <record id="sem_department_tree_action_t4tek" model="ir.actions.act_window">
            <field name="name">Departments.t4tek</field>
            <field name="res_model">hr.department</field>
            <field name="search_view_id" ref="view_department_filter_t4tek"/>
            <field name="domain">[("has_read_access", "=", True)]</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new department
                </p><p>
                    Structure Employees per department and have an overview of e.g.
                    expenses, timesheets, time off, recruitment, etc.
                </p>
            </field>
        </record>

        <record id="hr_department_tree_view_tree_action" model="ir.actions.act_window.view">
            <field name="sequence" eval="10"/>
            <field name="view_mode">list</field>
            <field name="act_window_id" ref="sem_department_tree_action_t4tek"/>
        </record>

        <record id="hr_department_form_view_tree_action" model="ir.actions.act_window.view">
            <field name="sequence" eval="15"/>
            <field name="view_mode">form</field>
            <field name="act_window_id" ref="sem_department_tree_action_t4tek"/>
        </record>

        <record id="hr_department_kanban_view_tree_action" model="ir.actions.act_window.view">
            <field name="sequence" eval="20"/>
            <field name="view_mode">kanban</field>
            <field name="act_window_id" ref="sem_department_tree_action_t4tek"/>
        </record>

        <record id="sem_department_action_t4tek" model="ir.actions.act_window">
            <field name="name">Phòng Ban</field>
            <field name="res_model">hr.department</field>
            <field name="view_mode">hierarchy,kanban,list</field>
            <field name="path">sem_departments_t4tek</field>
            <field name="domain">[("has_read_access", "=", True)]</field>
            <field name="search_view_id" ref="view_department_filter_t4tek"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new department
                </p><p>
                    Structure Employees per department and have an overview of e.g.
                    expenses, timesheets, time off, recruitment, etc.
                </p>
            </field>
        </record>

        <record id="hr_department_hierarchy_view_kanban_action" model="ir.actions.act_window.view">
            <field name="sequence" eval="5"/>
            <field name="view_mode">hierarchy</field>
            <field name="view_id" ref="view_hr_department_hierarchy"/>
            <field name="act_window_id" ref="sem_department_action_t4tek"/>
        </record>

        <record id="hr_department_kanban_view_kanban_action" model="ir.actions.act_window.view">
            <field name="sequence" eval="10"/>
            <field name="view_mode">kanban</field>
            <field name="view_id" ref="hr_department_view_kanban_t4tek"/>
            <field name="act_window_id" ref="sem_department_action_t4tek"/>
        </record>

        <record id="hr_department_tree_view_kanban_action" model="ir.actions.act_window.view">
            <field name="sequence" eval="15"/>
            <field name="view_mode">list</field>
            <field name="view_id" ref="view_department_tree_t4tek"/>
            <field name="act_window_id" ref="sem_department_action_t4tek"/>
        </record>

        <record id="hr_department_form_view_kanban_action" model="ir.actions.act_window.view">
            <field name="sequence" eval="20"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_department_form_t4tek"/>
            <field name="act_window_id" ref="sem_department_action_t4tek"/>
        </record>
        
        <record id="view_department_add_employee_popup_form" model="ir.ui.view">
            <field name="name">hr.department.form.add.employee.popup</field>
            <field name="model">hr.department</field>
            <field name="priority">1000</field>
            <field name="arch" type="xml">
                <form string="Thêm nhân viên vào phòng ban">
                    <field name="add_emp_has_conflict" invisible="1"/>
                    <field name="add_emp_confirmed" invisible="1"/>
                    
                    <sheet>
                        <div class="alert alert-warning text-center" role="alert" invisible="not add_emp_has_conflict">
                            <field name="add_emp_conflict_msg" readonly="1" nolabel="1"/>
                        </div>
                        <group invisible="add_emp_has_conflict">
                            <p class="text-muted">Chọn nhân viên để thêm vào phòng ban này. Các nhân viên đã thuộc phòng ban khác sẽ yêu cầu xác nhận chuyển.</p>
                            <field name="add_employee_ids" nolabel="1" 
                                   options="{'no_create': True}"
                                   domain="[('department_id', '!=', id)]">
                                <list create="0" delete="0" edit="0">
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="department_id"/>
                                    <field name="job_id"/>
                                </list>
                            </field>
                        </group>
                        
                        <group invisible="not add_emp_has_conflict">
                            <field name="add_employee_ids" nolabel="1" readonly="1">
                                <list create="0" delete="0" edit="0">
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="department_id"/>
                                    <field name="job_id"/>
                                </list>
                            </field>
                        </group>
                    </sheet>
                    
                    <footer>
                        <button name="action_add_employee_apply" string="Xác nhận" type="object" class="btn-primary" invisible="add_emp_has_conflict"/>
                        <button name="action_add_employee_apply" string="Tiếp tục chuyển" type="object" class="btn-warning" invisible="not add_emp_has_conflict"/>
                        <button string="Hủy" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
</odoo>
