<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_job_transfer_wizard_form" model="ir.ui.view">
        <field name="name">hr.job.transfer.wizard.form</field>
        <field name="model">hr.job.transfer.wizard</field>
        <field name="arch" type="xml">
            <form string="Chuyển giao chức vụ">
                <sheet>
                    <group>
                        <group string="Thông tin chuyển giao">
                            <field name="source_employee_id"/>
                            <field name="department_id"/>
                            <field name="job_id"/>
                        </group>
                        <group string="Chọn nhân viên nhận">
                            <field name="target_employee_id" options="{'no_create': True}"/>
                        </group>
                    </group>
                    <group>
                        <field name="note" placeholder="Nhập ghi chú về việc chuyển giao..."/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_transfer" type="object" string="Xác nhận chuyển giao"
                            class="btn-primary" confirm="Bạn có muốn chuyển giao chức vụ này cho nhân viên khác?"/>
                    <button string="Hủy" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
