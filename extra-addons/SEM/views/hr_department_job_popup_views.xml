<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_tree_simple_popup" model="ir.ui.view">
        <field name="name">hr.employee.list.simple.popup</field>
        <field name="model">hr.employee</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <list string="Nhân viên" create="0" edit="0" delete="0">
                <field name="code"/>
                <field name="name"/>
                <field name="department_id"/>
                <field name="job_id"/>
            </list>
        </field>
    </record>

    <record id="view_hr_department_job_members_form" model="ir.ui.view">
        <field name="name">hr.department.job.form.members</field>
        <field name="model">hr.department.job</field>
        <field name="arch" type="xml">
            <form string="Nhân viên nắm giữ">
                <sheet>
                    <group>
                        <group string="Thông tin bản lề">
                            <field name="job_id" readonly="1"/>
                            <field name="department_id" readonly="1"/>
                            <field name="company_id" invisible="1"/>
                        </group>
                    </group>
                    <!-- <group>
                        <group string="Thuộc tính chức vụ">
                            <field name="is_manager"/>
                            <field name="is_restricted"/>
                        </group>
                        <group string="Định biên">
                            <field name="max_employee" readonly="is_manager"/>
                            <field name="no_of_employee" readonly="1"/>
                            <field name="can_add_employee" invisible="1"/>
                        </group>
                    </group> -->
                    <separator string="Danh sách nhân viên nắm giữ"/>
                    <field name="member_ids" 
                           options="{'no_create': True, 'no_quick_create': True, 'no_create_edit': True, 'no_open': True}"
                           context="{'default_department_id': department_id, 'default_job_id': job_id, 'tree_view_ref': 'SEM.view_employee_tree_simple_popup', 'list_view_ref': 'SEM.view_employee_tree_simple_popup'}"
                           domain="[('department_id', '=', department_id), '|', ('job_id', '=', False), ('job_id', '=', job_id)]">
                        <list create="0" delete="0" edit="1" editable="bottom">
                            <field name="code" readonly="1"/>
                            <field name="name" readonly="1"/>
                            <field name="work_email" readonly="1"/>
                                
                            <button name="action_transfer_job" type="object" string="Chuyển giao chức vụ" 
                                    icon="fa-exchange" 
                                    class="text-primary"/>
                            <button name="action_remove_from_job" type="object" string="Gỡ khỏi chức vụ" 
                                    icon="fa-unlink" confirm="Bạn có chắc chắn muốn gỡ nhân viên này khỏi chức vụ hiện tại?"
                                    class="text-danger"/>
                        </list>
                    </field>
                </sheet>
                <footer>
                    <button string="Lưu" special="save" class="btn-primary"/>
                    <button string="Đóng" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>


</odoo>
