<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <!-- ===================== People Category ===================== -->
    <record id="view_people_category_form" model="ir.ui.view">
        <field name="name">people.category.form</field>
        <field name="model">people.category</field>
        <field name="arch" type="xml">
            <form string="Dân Tộc">
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_people_category_list" model="ir.ui.view">
        <field name="name">people.category.list</field>
        <field name="model">people.category</field>
        <field name="arch" type="xml">
            <list string="Dân Tộc">
                <field name="code"/>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="action_people_category" model="ir.actions.act_window">
        <field name="name">Dân Tộc</field>
        <field name="res_model">people.category</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>