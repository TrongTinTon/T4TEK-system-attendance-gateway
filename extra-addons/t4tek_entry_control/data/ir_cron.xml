<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
    <!--
        Scheduled Action: creates daily hr.attendance records from Gatekeeper
        Attendance Logs.

        IMPORTANT:
        - Cron is intentionally installed/updated as inactive.
        - This prevents automatic attendance creation immediately after module
          installation or upgrade.
        - Admin can enable or run it manually later from:
          Settings -> Technical -> Automation -> Scheduled Actions.
    -->
    <record id="ir_cron_entry_control_create_daily_attendances" model="ir.cron">
        <field name="name">Gatekeeper: Create Daily Attendances</field>
        <field name="model_id" ref="model_entry_control_attendance_log"/>
        <field name="state">code</field>
        <field name="code">model.cron_create_daily_attendances()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <!-- 17:15 UTC = 00:15 Asia/Ho_Chi_Minh on the next local business day.
             The cron remains inactive by default so module update will not run attendance creation unexpectedly. -->
        <field name="nextcall" eval="time.strftime('%Y-%m-%d 17:15:00')"/>
        <field name="active">False</field>
    </record>
    </data>
</odoo>
