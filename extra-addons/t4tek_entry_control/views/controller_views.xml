<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_entry_control_controller_list" model="ir.ui.view">
        <field name="name">entry.control.controller.list</field>
        <field name="model">entry.control.controller</field>
        <field name="arch" type="xml">
            <list string="Controllers" create="1" edit="1"
                  decoration-success="operational_state == 'online'"
                  decoration-warning="operational_state == 'warning'"
                  decoration-danger="operational_state in ('offline','blocked')">
                <field name="operational_state" widget="badge"/>
                <field name="controller_code"/>
                <field name="name"/>
                <field name="registration_status"/>
                <field name="attendance_direction_mode" optional="show"/>
                <field name="last_seen_at"/>
                <field name="online_device_count" string="Online"/>
                <field name="offline_device_count" string="Offline"/>
                <field name="error_device_count" string="Errors"/>
                <field name="status_summary"/>
                <button name="action_block" type="object" string="Block" groups="t4tek_entry_control.group_entry_control_manager" invisible="registration_status == 'blocked'"/>
                <button name="action_unblock" type="object" string="Unblock" groups="t4tek_entry_control.group_entry_control_manager" invisible="registration_status != 'blocked'"/>
            </list>
        </field>
    </record>

    <record id="view_entry_control_controller_form" model="ir.ui.view">
        <field name="name">entry.control.controller.form</field>
        <field name="model">entry.control.controller</field>
        <field name="arch" type="xml">
            <form string="Controller">
                <header>
                    <button name="action_block" type="object" string="Block Controller" class="btn-secondary" groups="t4tek_entry_control.group_entry_control_manager" invisible="registration_status == 'blocked'"/>
                    <button name="action_unblock" type="object" string="Unblock Controller" class="btn-primary" groups="t4tek_entry_control.group_entry_control_manager" invisible="registration_status != 'blocked'"/>
                    <button name="action_regenerate_token" type="object" string="Reset Tokens" class="btn-secondary" groups="t4tek_entry_control.group_entry_control_manager" invisible="registration_status == 'blocked'"/>
                    <field name="registration_status" widget="statusbar" statusbar_visible="approved,blocked"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Controller name"/></h1>
                        <h3><field name="controller_code" readonly="1"/></h3>
                    </div>

                    <group string="Trạng thái vận hành">
                        <group>
                            <field name="operational_state" widget="badge" readonly="1"/>
                            <field name="status_summary" readonly="1"/>
                            <field name="approved" readonly="1"/>
                            <field name="blocked" readonly="1"/>
                            <field name="attendance_direction_mode"/>
                        </group>
                        <group>
                            <field name="last_seen_at" readonly="1"/>
                            <field name="last_hello_at" readonly="1"/>
                            <field name="last_auth_at" readonly="1"/>
                            <field name="last_device_report_at" readonly="1"/>
                        </group>
                    </group>

                    <group string="Thiết bị trực thuộc">
                        <group>
                            <field name="device_count" readonly="1"/>
                            <field name="online_device_count" readonly="1"/>
                        </group>
                        <group>
                            <field name="offline_device_count" readonly="1"/>
                            <field name="error_device_count" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Auth Token">
                            <group>
                                <group>
                                    <field name="auth_user_id" readonly="1"/>
                                    <field name="token_hint" readonly="1"/>
                                    <field name="token_issued_at" readonly="1"/>
                                    <field name="token_expires_at" readonly="1"/>
                                </group>
                                <group>
                                    <field name="refresh_token_hint" readonly="1"/>
                                    <field name="refresh_token_issued_at" readonly="1"/>
                                    <field name="refresh_token_expires_at" readonly="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="Controller Info">
                            <group>
                                <field name="controller_name" readonly="1"/>
                                <field name="server_base_url" readonly="1"/>
                                <field name="app_version" readonly="1"/>
                                <field name="machine_name" readonly="1"/>
                                <field name="local_ip" readonly="1"/>
                            </group>
                        </page>
                        <page string="Security">
                            <group>
                                <field name="public_key_pem" readonly="1"/>
                                <field name="key_fingerprint" readonly="1"/>
                                <field name="private_key_ref" readonly="1"/>
                            </group>
                        </page>
                        <page string="Lỗi gần nhất">
                            <field name="last_error" readonly="1" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_entry_control_controller_search" model="ir.ui.view">
        <field name="name">entry.control.controller.search</field>
        <field name="model">entry.control.controller</field>
        <field name="arch" type="xml">
            <search string="Controllers">
                <field name="controller_code"/>
                <field name="name"/>
                <filter name="online" string="Online" domain="[('registration_status','=','approved'),('blocked','=',False)]"/>
                <filter name="blocked" string="Blocked" domain="['|',('blocked','=',True),('registration_status','=','blocked')]"/>
            </search>
        </field>
    </record>

    <record id="action_entry_control_controller" model="ir.actions.act_window">
        <field name="name">Controllers</field>
        <field name="res_model">entry.control.controller</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_entry_control_controller_search"/>
    </record>
</odoo>
