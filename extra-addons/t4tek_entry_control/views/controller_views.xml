<odoo>
    <record id="view_entry_control_controller_tree" model="ir.ui.view">
        <field name="name">entry.control.controller.list</field>
        <field name="model">entry.control.controller</field>
        <field name="arch" type="xml">
            <list string="Controllers">
                <field name="controller_uid"/>
                <field name="name"/>
                <field name="status" widget="badge" decoration-success="status == 'online'" decoration-danger="status == 'blocked'" decoration-muted="status == 'offline'"/>
                <field name="last_sync_at"/>
                <field name="last_heartbeat_at"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_entry_control_controller_form" model="ir.ui.view">
        <field name="name">entry.control.controller.form</field>
        <field name="model">entry.control.controller</field>
        <field name="arch" type="xml">
            <form string="Controller">
                <header>
                    <button name="action_generate_secret_key" type="object" string="Generate Key" class="btn-primary" groups="base.group_system"/>
                    <button name="action_copy_secret_key" type="object" string="Copy" class="btn-secondary" groups="base.group_system" invisible="not secret_key"/>
                    <button name="action_block" type="object" string="Block" invisible="status == 'blocked'" class="btn-secondary"/>
                    <button name="action_unblock" type="object" string="Unblock" invisible="status != 'blocked'" class="btn-primary"/>
                    <field name="status" widget="statusbar" statusbar_visible="offline,online,blocked"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="controller_uid" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Identity">
                            <field name="name" string="Controller Name"/>
                            <field name="controller_uid"/>
                            <field name="secret_key" widget="CopyClipboardChar" groups="base.group_system"/>
                            <field name="active"/>
                        </group>
                        <group string="Runtime Status">
                            <field name="last_auth_at" readonly="1"/>
                            <field name="last_sync_at" readonly="1"/>
                            <field name="last_heartbeat_at" readonly="1"/>
                            <field name="token_hint" readonly="1"/>
                            <field name="token_expires_at" readonly="1"/>
                            <field name="last_error" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Devices">
                            <field name="device_ids" context="{'default_controller_id': id}">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="serial_number"/>
                                    <field name="model"/>
                                    <field name="firmware_version"/>
                                    <field name="ip_address"/>
                                    <field name="status" widget="badge"/>
                                    <field name="last_seen_at"/>
                                    <field name="active"/>
                                </list>
                            </field>
                        </page>
                        <page string="Employees Synced">
                            <field name="employee_sync_ids" context="{'default_controller_id': id}">
                                <list>
                                    <field name="employee_id"/>
                                    <field name="employee_name"/>
                                    <field name="pin"/>
                                    <field name="last_synced_at"/>
                                    <field name="sync_status" widget="badge" decoration-success="sync_status == 'success'" decoration-danger="sync_status == 'failed'"/>
                                    <field name="error_message"/>
                                </list>
                            </field>
                        </page>
                        <page string="Attendance Logs">
                            <field name="attendance_log_ids">
                                <list>
                                    <field name="employee_id"/>
                                    <field name="pin"/>
                                    <field name="direction" widget="badge"/>
                                    <field name="check_time"/>
                                    <field name="device_timezone"/>
                                    <field name="device_id"/>
                                    <field name="verify_method"/>
                                    <field name="sync_status" widget="badge"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_entry_control_controller" model="ir.actions.act_window">
        <field name="name">Controllers</field>
        <field name="res_model">entry.control.controller</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
