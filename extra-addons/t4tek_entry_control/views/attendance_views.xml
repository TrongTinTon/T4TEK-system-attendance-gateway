<odoo>
    <record id="view_entry_control_create_attendance_wizard_form" model="ir.ui.view">
        <field name="name">entry.control.create.attendance.wizard.form</field>
        <field name="model">entry.control.create.attendance.wizard</field>
        <field name="arch" type="xml">
            <form string="Create Attendances">
                <group>
                    <field name="month"/>
                    <field name="year"/>
                </group>
                <footer>
                    <button name="action_create_attendances"
                            type="object"
                            string="Create Attendances"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_entry_control_create_attendance_wizard" model="ir.actions.act_window">
        <field name="name">Create Attendances</field>
        <field name="res_model">entry.control.create.attendance.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>


    <record id="view_entry_control_attendance_log_tree" model="ir.ui.view">
        <field name="name">entry.control.attendance.log.list</field>
        <field name="model">entry.control.attendance.log</field>
        <field name="arch" type="xml">
            <list string="Attendance Logs" decoration-danger="sync_status == 'failed'" decoration-muted="sync_status == 'skipped'">
                <header>
                    <button name="%(action_entry_control_create_attendance_wizard)d"
                            type="action"
                            string="Create Attendances"
                            class="btn-primary"
                            display="always"/>
                </header>
                <field name="employee_id"/>
                <field name="direction" widget="badge" decoration-success="direction == 'in'" decoration-info="direction == 'out'"/>
                <field name="time_display" string="Time"/>
                <field name="module_time_now" string="Module Time Now" optional="show"/>
                <field name="module_timezone_display" string="Module Timezone" optional="show"/>
                <field name="serial_number" string="Device"/>
                <field name="device_timezone" optional="show"/>
                <field name="verify_method"/>
                <field name="message" optional="show"/>
                <field name="sync_status" widget="badge" decoration-success="sync_status == 'success'" decoration-danger="sync_status == 'failed'" decoration-muted="sync_status == 'skipped'"/>
            </list>
        </field>
    </record>
    <record id="view_entry_control_attendance_log_form" model="ir.ui.view">
        <field name="name">entry.control.attendance.log.form</field>
        <field name="model">entry.control.attendance.log</field>
        <field name="arch" type="xml">
            <form string="Attendance Log">
                <sheet>
                    <group>
                        <group string="Source">
                            <field name="controller_id"/>
                            <field name="serial_number" string="Device"/>
                            <field name="device_timezone"/>
                            <field name="device_id"/>
                            <field name="employee_id"/>
                        </group>
                        <group string="Attendance">
                            <field name="direction"/>
                            <field name="time_display" string="Time" readonly="1"/>
                            <field name="module_time_now" string="Module Time Now" readonly="1"/>
                            <field name="module_timezone_display" string="Module Timezone" readonly="1"/>
                            <field name="check_time" string="Check Time (UTC Storage)" readonly="1"/>
                            <field name="verify_method"/>
                            <field name="verify_type"/>
                        </group>
                    </group>
                    <group string="Odoo Attendances">
                        <field name="hr_attendance_id"/>
                        <field name="sync_status"/>
                        <field name="message"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_entry_control_attendance_log_search" model="ir.ui.view">
        <field name="name">entry.control.attendance.log.search</field>
        <field name="model">entry.control.attendance.log</field>
        <field name="arch" type="xml">
            <search string="Attendance Logs">
                <field name="employee_id"/>
                <field name="serial_number" string="Device"/>
                <field name="device_timezone"/>
                <field name="device_id"/>
                <field name="direction"/>
                <filter name="filter_check_in" string="Check In" domain="[('direction','=','in')]"/>
                <filter name="filter_check_out" string="Check Out" domain="[('direction','=','out')]"/>
                <filter name="filter_sync_failed" string="Failed" domain="[('sync_status','=','failed')]"/>
                <filter name="filter_system_generated" string="System Generated" domain="[('verify_method','=','system_generated')]"/>
            </search>
        </field>
    </record>
    <record id="action_entry_control_attendance_log" model="ir.actions.act_window">
        <field name="name">Attendance Logs</field>
        <field name="res_model">entry.control.attendance.log</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
