<odoo>
    <record id="view_entry_control_attendance_log_tree" model="ir.ui.view">
        <field name="name">entry.control.attendance.log.list</field>
        <field name="model">entry.control.attendance.log</field>
        <field name="arch" type="xml">
            <list string="Attendance Logs" decoration-danger="sync_status == 'failed'" decoration-muted="sync_status == 'skipped'">
                <field name="employee_id"/>
                <field name="pin"/>
                <field name="direction" widget="badge" decoration-success="direction == 'in'" decoration-info="direction == 'out'"/>
                <field name="check_time"/>
                <field name="device_timezone"/>
                <field name="device_id"/>
                <field name="verify_method"/>
                <field name="check_type"/>
                <field name="direction_source" widget="badge"/>
                <field name="sync_status" widget="badge" decoration-success="sync_status == 'success'" decoration-danger="sync_status == 'failed'" decoration-muted="sync_status == 'skipped'"/>
                <field name="error_message"/>
            </list>
        </field>
    </record>
    <record id="view_entry_control_attendance_log_form" model="ir.ui.view">
        <field name="name">entry.control.attendance.log.form</field>
        <field name="model">entry.control.attendance.log</field>
        <field name="arch" type="xml">
            <form string="Attendance Log">
                <sheet>
                    <group>
                        <group string="Source">
                            <field name="controller_id"/>
                            <field name="device_id"/>
                            <field name="employee_id"/>
                            <field name="pin"/>
                        </group>
                        <group string="Attendance">
                            <field name="direction"/>
                            <field name="direction_source"/>
                            <field name="device_direction"/>
                            <field name="check_time"/>
                            <field name="device_check_time"/>
                            <field name="device_timezone"/>
                            <field name="verify_method"/>
                            <field name="verify_type"/>
                            <field name="check_type"/>
                            <field name="device_check_type"/>
                        </group>
                    </group>
                    <group string="Odoo Attendances">
                        <field name="hr_attendance_id"/>
                        <field name="sync_status"/>
                        <field name="error_message"/>
                        <field name="event_hash"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_entry_control_attendance_log_search" model="ir.ui.view">
        <field name="name">entry.control.attendance.log.search</field>
        <field name="model">entry.control.attendance.log</field>
        <field name="arch" type="xml">
            <search string="Attendance Logs">
                <field name="employee_id"/>
                <field name="pin"/>
                <field name="device_id"/>
                <field name="direction"/>
                <filter name="filter_check_in" string="Check In" domain="[('direction','=','in')]"/>
                <filter name="filter_check_out" string="Check Out" domain="[('direction','=','out')]"/>
                <filter name="filter_sync_failed" string="Failed" domain="[('sync_status','=','failed')]"/>
            </search>
        </field>
    </record>
    <record id="action_entry_control_attendance_log" model="ir.actions.act_window">
        <field name="name">Attendance Logs</field>
        <field name="res_model">entry.control.attendance.log</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
