<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ========== EXPORT FORM VIEW ========== -->
    <record id="view_core_app_export_import_form_export" model="ir.ui.view">
        <field name="name">core.app.export.import.form.export</field>
        <field name="model">core.app.export.import</field>
        <field name="arch" type="xml">
            <form string="Export CoreApp Data">
                <sheet>
                    <div class="alert alert-info" role="alert">
                        <strong>Export CoreApp Configuration</strong>
                        <p>Select the data you want to export. All data will be saved in JSON format.</p>
                    </div>
                    
                    <group>
                        <group string="Select Data to Export">
                            <field name="operation" invisible="1"/>
                            <field name="export_categories"/>
                            <field name="export_groups"/>
                            <field name="export_roles"/>
                            <field name="export_menus"/>
                            <field name="export_users"/>
                        </group>
                        
                        <group string="Options">
                            <field name="export_user_passwords" invisible="not export_users"/>
                        </group>
                    </group>

                    <!-- Show export result -->
                    <group invisible="not context.get('show_export_result')">
                        <field name="export_filename" invisible="1"/>
                        <field name="export_data" filename="export_filename" widget="binary"/>
                    </group>

                    <div class="alert alert-warning" role="alert" invisible="not export_user_passwords or not export_users">
                        <i class="fa fa-warning"/> <strong>Security Warning:</strong> 
                        User passwords will NOT be exported for security reasons. 
                        Users will need to reset their passwords after import.
                    </div>
                </sheet>
                
                <footer>
                    <button string="Export" name="action_export" type="object" 
                            class="btn-primary" 
                            invisible="context.get('show_export_result')"/>
                    <button string="Close" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ========== IMPORT FORM VIEW ========== -->
    <record id="view_core_app_export_import_form_import" model="ir.ui.view">
        <field name="name">core.app.export.import.form.import</field>
        <field name="model">core.app.export.import</field>
        <field name="arch" type="xml">
            <form string="Import CoreApp Data">
                <sheet>
                    <div class="alert alert-warning" role="alert">
                        <strong><i class="fa fa-warning"/> Important!</strong>
                        <ul>
                            <li>Make sure to backup your database before importing</li>
                            <li>Import will modify existing data based on the selected mode</li>
                            <li>Some data may be skipped if dependencies are missing</li>
                        </ul>
                    </div>
                    
                    <group invisible="context.get('show_import_result')">
                        <group string="Import File">
                            <field name="operation" invisible="1"/>
                            <field name="import_file" filename="import_filename" widget="binary"/>
                            <field name="import_filename" invisible="1"/>
                        </group>
                        
                        <group string="Import Options">
                            <field name="import_mode" widget="radio"/>
                        </group>
                    </group>

                    <!-- Import mode descriptions -->
                    <group invisible="context.get('show_import_result')">
                        <div class="alert alert-info" role="alert">
                            <strong>Import Modes:</strong>
                            <ul>
                                <li><strong>Create Only:</strong> Only create new records, skip existing ones</li>
                                <li><strong>Update Only:</strong> Only update existing records, skip new ones</li>
                                <li><strong>Create &amp; Update:</strong> Create new and update existing records</li>
                            </ul>
                        </div>
                    </group>

                    <!-- Show import result -->
                    <group invisible="not context.get('show_import_result')">
                        <div class="alert alert-success" role="alert">
                            <strong><i class="fa fa-check-circle"/> Import Completed!</strong>
                            <p>Check the log below for details.</p>
                        </div>
                        <field name="import_log" widget="text" readonly="1" 
                               colspan="2" nolabel="1"
                               style="font-family: monospace; white-space: pre-wrap; height: 400px;"/>
                    </group>
                </sheet>
                
                <footer>
                    <button string="Import" name="action_import" type="object" 
                            class="btn-primary" 
                            invisible="context.get('show_import_result')"/>
                    <button string="Close" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ========== EXPORT ACTION ========== -->
    <record id="action_core_app_export" model="ir.actions.act_window">
        <field name="name">Export Data</field>
        <field name="res_model">core.app.export.import</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_operation': 'export'}</field>
        <field name="view_id" ref="view_core_app_export_import_form_export"/>
    </record>

    <!-- ========== IMPORT ACTION ========== -->
    <record id="action_core_app_import" model="ir.actions.act_window">
        <field name="name">Import Data</field>
        <field name="res_model">core.app.export.import</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_operation': 'import'}</field>
        <field name="view_id" ref="view_core_app_export_import_form_import"/>
    </record>

    <!-- ========== ADD TO MENU ========== -->
    <menuitem 
        id="menu_core_app_export_import_section"
        name="Data Management"
        parent="CoreApp.app_management_root_menu"
        sequence="99"
        groups="CoreApp.group_CoreApp_admin"/>

    <menuitem 
        id="menu_core_app_export"
        name="Export Data"
        parent="menu_core_app_export_import_section"
        action="action_core_app_export"
        sequence="1"
        groups="CoreApp.group_CoreApp_admin"/>

    <menuitem 
        id="menu_core_app_import"
        name="Import Data"
        parent="menu_core_app_export_import_section"
        action="action_core_app_import"
        sequence="2"
        groups="CoreApp.group_CoreApp_admin"/>

</odoo>