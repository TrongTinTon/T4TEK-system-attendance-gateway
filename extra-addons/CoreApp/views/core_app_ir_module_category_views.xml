<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="CoreApp_ir_module_category_view_list" model="ir.ui.view">
        <field name="name">CoreApp.ir.module.category.list</field>
        <field name="model">ir.module.category</field>
        <field name="priority">999</field>
        <field name="arch" type="xml">
            <list string=" Categories" create="1">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="parent_id"/>
            </list>
        </field>
    </record>

    <record id="CoreApp_ir_module_category_view_form_app" model="ir.ui.view">
        <field name="name">CoreApp.ir.module.category.form.app</field>
        <field name="model">ir.module.category</field>
        <field name="priority">999</field>
        <field name="arch" type="xml">
            <form string="Category" create = "1" edit="1" delete="1">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Category..."/></h1>
                    </div>
                    <notebook>
                        <page string="Features" name="features">
                            <field name="child_ids" context="{'default_is_from_CoreApp': True}">
                                <list editable="bottom" create="1" edit="1" delete="1">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="parent_id" column_invisible="True" force_save="1"/>
                                    <field name="is_from_CoreApp" column_invisible="True" force_save="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter class="oe_chatter">
                    <field name ="message_follower_ids"/>
                    <field name ="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>

    <record id="CoreApp_ir_module_category_view_form_feature" model="ir.ui.view">
        <field name="name">CoreApp.ir.module.category.form.feature</field>
        <field name="model">ir.module.category</field>
        <field name="priority">999</field>
        <field name="arch" type="xml">
            <form string="Feature" create="1" edit="1" delete="1">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Feature..."/></h1>
                    </div>
                    <group>
                        <field name="parent_id" string="Category" 
                        options="{'no_create': True}" required="1" 
                        domain="[('parent_id', '=', False), ('is_from_CoreApp', '=', True)]"/>
                        
                        <field name="description" nolabel="1" placeholder="Description..."/>
                        <field name="is_from_CoreApp" readonly="1" invisible="1"/>
                    </group>
                </sheet>
                <chatter class="oe_chatter">
                    <field name ="message_follower_ids"/>
                    <field name ="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>

    <record id="CoreApp_ir_module_category_action_apps" model="ir.actions.act_window">
        <field name="name">Categories</field>
        <field name="res_model">ir.module.category</field>
        <field name="view_mode">list,form</field>
        <field name="domain" eval="[('parent_id', '=', False), ('is_from_CoreApp', '=', True)]"/>
        <field name="context">{'default_parent_id': False, 'default_is_from_CoreApp': True}</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('CoreApp_ir_module_category_view_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('CoreApp_ir_module_category_view_form_app')})
        ]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create new Category.
            </p>
        </field>
        <field name="group_ids" eval="[(4, ref('CoreApp.group_CoreApp_admin'))]"/>
    </record>

    <record id="CoreApp_ir_module_category_action_features" model="ir.actions.act_window">
        <field name="name">Features</field>
        <field name="res_model">ir.module.category</field>
        <field name="view_mode">list,form</field>
        <field name="domain" eval="[('parent_id', '!=', False), ('is_from_CoreApp', '=', True)]"/>
        <field name="context">{'default_is_from_CoreApp': True}</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('CoreApp_ir_module_category_view_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('CoreApp_ir_module_category_view_form_feature')})
        ]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create new Feature.
            </p>
        </field>
        <field name="group_ids" eval="[(4, ref('CoreApp.group_CoreApp_admin'))]"/>
    </record>
</odoo>