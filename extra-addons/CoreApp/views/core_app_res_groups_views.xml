<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="CoreApp_group_view_list" model="ir.ui.view">
        <field name="name">core.app.group.list.simplified</field>
        <field name="model">res.groups</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <list create="1" edit="1" delete="1">
                <field name="name"/>
                <field name="category_id"/>
                <field name="privilege_id"/>
            </list>
        </field>
    </record>

    <record id="CoreApp_group_view_form" model="ir.ui.view">
        <field name="name">core.app.group.form.simplified</field>
        <field name="model">res.groups</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <form create="1" edit="1" delete="1">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="category_id" options="{'no_create': True, 'no_open': True}" required="1"
                        domain="[('is_from_CoreApp', '=', True)]"/>
                    </group>
                    <notebook>
                        <page name="inherited" string="Inherited">
                           <field name="implied_ids"
                                options="{
                                    'open': False, 
                                    'no_open': True,
                                    'create': False,
                                    'edit': False,
                                    'delete': False
                                }"
                                context="{
                                    'list_view_ref': 'CoreApp.CoreApp_group_view_list',
                                    'form_view_ref': 'CoreApp.CoreApp_group_view_form_readonly'
                                }"
                                domain="[('is_from_CoreApp', '=', False)]"
                            />
                        </page>
                    </notebook>
                </sheet>
                <chatter class="oe_chatter">
                    <field name ="message_follower_ids"/>
                    <field name ="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>

    <record id="CoreApp_group_view_form_readonly" model="ir.ui.view">
        <field name="name">core.app.group.form.simplified.readonly</field>
        <field name="model">res.groups</field>
        <field name="priority">31</field>
        <field name="arch" type="xml">
            <form create="false" edit="false" delete="false">
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="category_id" readonly="1" options="{'create': False, 'open': False}" required="1" 
                        domain="[('is_from_CoreApp', '=', True)]"/>
                    </group>
                </sheet>
                <!-- <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div> -->
                <footer>
                <button 
                    string="OK" 
                    class="btn-primary" 
                    special="cancel"/>
            </footer>
            </form>
        </field>
    </record>

    <record id="CoreApp_group_action" model="ir.actions.act_window">
        <field name="name">Groups</field>
        <field name="res_model">res.groups</field>
        <field name="view_mode">list,form</field>
        <field name="domain" eval="[('category_id.is_from_CoreApp', '=', True)]"/>
        <field name="context">{'search_default_group_by_category_id': 1, 'default_is_from_CoreApp': True}</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('CoreApp_group_view_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('CoreApp_group_view_form')})
        ]"/>
    </record>
</odoo>