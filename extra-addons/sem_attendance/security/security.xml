<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        

    <record id="t4tek_sem_attendance_group" model="ir.module.category">
        <field name="name">T4TEK SEM Attendance Role</field>
        <field name="sequence">500</field>
    </record>

    <record id="t4tek_sem_attendance_group_privilege" model="res.groups.privilege">
        <field name="name">T4TEK SEM Attendance Role</field>
        <field name="sequence">500</field>
        <field name="category_id" ref="t4tek_sem_attendance_group"/>
    </record>
    
    <record id="sem_attendance_officer" model="res.groups">
        <field name="name">Nhân viên chấm công (SEM)</field>
        <field name="privilege_id" ref="t4tek_sem_attendance_group_privilege" />
        <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('hr_attendance.group_hr_attendance_officer'))]" />
    </record>

    <record id="sem_attendance_user" model="res.groups">
        <field name="name">Nhân viên phụ trách chấm công (SEM)</field>
        <field name="privilege_id" ref="t4tek_sem_attendance_group_privilege" />
        <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('hr_attendance.group_hr_attendance_user')), (4, ref('sem_attendance_officer'))]" />
    </record>

    <!-- Nhóm người dùng có quyền cập nhật lịch chấm công -->
    <record id="group_attendance_calendar_updater" model="res.groups">
        <field name="name">Cập nhật lịch chấm công</field>
        <field name="comment">Cho phép người dùng thủ công cập nhật lại lịch làm việc để tính lại số công từ chấm công cũ.</field>
    </record>

    <record id="sem_attendance_manager" model="res.groups">
        <field name="name">Quản lý chấm công (SEM)</field>
        <field name="privilege_id" ref="t4tek_sem_attendance_group_privilege" />
        <field name="implied_ids" eval="[(4, ref('sem_attendance_user')), (4, ref('group_attendance_calendar_updater'))]" />
    </record>
    </data>
</odoo>
