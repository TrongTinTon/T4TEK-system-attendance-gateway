<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sem_attendance_config_view_form" model="ir.ui.view">
        <field name="name">sem.attendance.config.settings.view.form</field>
        <field name="model">sem.attendance.config.settings</field>
        <field name="priority" eval="99"/>
        <field name="arch" type="xml">
            <form string="Cấu hình chấm công" class="oe_form_configuration" create="false" edit="1" delete="false">
                <style>
                    .o_control_panel { display: none !important; }
                </style>
                <header>
                    <button string="Lưu" type="object" name="execute" class="oe_highlight" />
                </header>
                <sheet>
                    <group>
                        <field name="company_id" options="{'no_create': True}" invisible="1"/>
                    </group>
                    <div class="o_setting_container">
                        <div class="o_setting_box">
                            <div class="o_horizontal_separator">Cấu hình tham số chấm công (SEM)</div>
                            <div class="row mt16 o_settings_container">
                                <div class="col-12 col-lg-6 o_setting_box">
                                    <div class="o_setting_right_pane">
                                        <label for="late_allow_time"/>
                                        <div class="text-muted">
                                            Thời gian cho phép đi trễ (phút)
                                        </div>
                                        <div class="content-group">
                                            <div class="mt16">
                                                <field name="late_allow_time" class="oe_inline"/>
                                                <span> Phút</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-12 col-lg-6 o_setting_box">
                                    <div class="o_setting_right_pane">
                                        <label for="early_allow_time"/>
                                        <div class="text-muted">
                                           Thời gian cho phép về sớm (phút)
                                        </div>
                                        <div class="content-group">
                                            <div class="mt16">
                                                <field name="early_allow_time" class="oe_inline"/>
                                                <span> Phút</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="hr_settings_action" model="ir.actions.act_window">
        <field name="name">Cấu hình chấm công</field>
        <field name="res_model">sem.attendance.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
        <field name="view_id" ref="sem_attendance_config_view_form"/>
    </record>

</odoo>