    <record id="sem_employee_form_view_inherit" model="ir.ui.view">
        <field name="name">sem.employee.form.view.inherit</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="SEM.view_employee_form_t4tek"/>
        <field name="priority">110</field>
        <field name="arch" type="xml">
            <button name="action_open_versions" position="before">
                <field name="attendance_state" invisible="1"/>
                <field name="hours_last_month" invisible="1"/>
                <button name="action_open_last_month_attendances"
                        class="oe_stat_button"
                        icon="fa-clock-o"
                        type="object"
                        help="Worked hours this month">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_value">
                            <field name="hours_last_month" widget="float_time"/>
                            <span class="o_stat_value text-success" invisible="hours_last_month_overtime &lt;= 0 or not display_extra_hours">
                                (+<field name="hours_last_month_overtime" widget="float_time"/>)
                            </span>
                            <span class="o_stat_value text-danger" invisible="hours_last_month_overtime &gt;= 0 or not display_extra_hours">
                                (<field name="hours_last_month_overtime" widget="float_time"/>)
                            </span>
                        </span>
                        <span class="o_stat_text">
                            Monthly Hours
                        </span>
                    </div>
                </button>
            </button>
            <xpath expr="//group[@name='managers']" position="inside">
                <field name="attendance_manager_id" string="Quản lý chấm công" widget="many2one_avatar_user" />
            </xpath>
            <xpath expr="//field[@name='barcode']" position="attributes">
                <attribute name="string">Mã RFID/Thẻ</attribute>
            </xpath>
            <xpath expr="//button[@name='generate_random_barcode']" position="after">
                <button name="open_barcode_scanner" string="Đọc thẻ" type="object" class="btn btn-link" invisible="barcode"/>
            </xpath>
            <!-- identification_group -->
            <group name="identification_group" position="inside">
                <field 
                    name="ruleset_id" string="Overtime Ruleset"
                    placeholder="Select a ruleset to manage overtime."
                    invisible="1"
                    />
            </group>
        </field>
    </record>

    <record id="sem_employee_tree_view_inherit_leave" model="ir.ui.view">
        <field name="name">sem.employee.tree.view.inherit</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="SEM.view_employee_tree_t4tek"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='work_location_id']" position="after">
                <field name="attendance_manager_id" optional="hide" widget="many2one_avatar_user"/>
            </xpath>
        </field>
    </record>

   

</odoo>
