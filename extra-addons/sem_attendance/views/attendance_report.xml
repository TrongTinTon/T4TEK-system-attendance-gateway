<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 1. Giao diện List (Tree) dành riêng cho Báo Cáo: Tắt Mới, Sửa, Xóa -->
    <record id="hr_attendance_view_list_report_t4tek" model="ir.ui.view">
        <field name="name">hr.attendance.list.report.t4tek</field>
        <field name="model">hr.attendance</field>
        <field name="arch" type="xml">
            <list string="Dữ liệu báo cáo chấm công" create="0" edit="0" delete="0" decoration-danger="attendance_type in ('absent', 'late_and_early')" decoration-warning="attendance_type == 'early_leave'" decoration-info="attendance_type == 'late'" decoration-primary="attendance_type == 'halfday'" decoration-success="attendance_type == 'normal'">
                <field name="employee_id" widget="many2one_avatar_employee"/>
                <field name="department_id" optional="show"/>
                <field name="check_in"/>
                <field name="check_out"/>
                <field name="worked_hours" widget="float_time" string="Giờ làm việc" sum="Tổng"/>
                <!-- <field name="duration_attendance" string="Số công" sum="Tổng"/> -->
                <field name="late_minutes" widget="float_time" string="Phút trễ" sum="Tổng" optional="show"/>
                <field name="overtime_hours" widget="float_time" string="Tăng ca" sum="Tổng" optional="show"/>
                <field name="attendance_type" widget="badge" decoration-danger="attendance_type in ('absent', 'late_and_early')" decoration-warning="attendance_type == 'early_leave'" decoration-info="attendance_type == 'late'" decoration-primary="attendance_type == 'halfday'" decoration-success="attendance_type == 'normal'" string="Trạng thái"/>
            </list>
        </field>
    </record>

    <!-- 2. Giao diện Kanban (Thẻ) - Tắt Tạo/Sửa/Xóa -->
    <record id="view_hr_attendance_kanban_t4tek" model="ir.ui.view">
        <field name="name">hr.attendance.kanban.t4tek</field>
        <field name="model">hr.attendance</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" sample="1" create="0" edit="0" delete="0">
                <field name="check_in"/>
                <field name="check_out"/>
                <templates>
                    <t t-name="card">
                        <field name="employee_id" widget="many2one_avatar_user" options="{'display_avatar_name': True}" class="fs-5 fw-bold mb-2"/>
                        <hr class="mt4 mb8"/>
                        <div>
                            <i class="fa fa-calendar me-1" aria-label="Period" role="img" title="Period"></i>
                            <field name="check_in" /> - <field name="check_out" />
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- 3. Giao diện Graph (Biểu đồ) -->
    <record id="hr_attendance_view_graph_t4tek" model="ir.ui.view">
        <field name="name">hr.attendance.graph.t4tek</field>
        <field name="model">hr.attendance</field>
        <field name="arch" type="xml">
            <graph string="Worked Hours" type="line" stacked="0" sample="1">
                <field name="employee_id" type="row"/>
                <field name="check_in" interval="week" type="col"/>
                <field name="overtime_hours" widget="float_time"/>
                <field name="worked_hours" type="measure" widget="float_time"/>
            </graph>
        </field>
    </record>

    <!-- 4. Giao diện Pivot (Ma trận) -->
    <record id="hr_attendance_view_pivot_t4tek" model="ir.ui.view">
        <field name="name">hr.attendance.pivot.t4tek</field>
        <field name="model">hr.attendance</field>
        <field name="arch" type="xml">
            <pivot string="Worked Hours">
                <field name="employee_id" type="row"/>
                <field name="check_in" type="col" interval="month"/>
                <field name="worked_hours" type="measure" widget="float_time"/>
                <field name="expected_hours" type="measure" widget="float_time"/>
                <field name="overtime_hours" string="Difference" type="measure" widget="float_time"/>
                <field name="validated_overtime_hours" string="Balance" type="measure" widget="float_time"/>
            </pivot>
        </field>
    </record>

    <!-- 4. Giao diện Search (Bộ lọc) -->
    <record id="hr_attendance_view_filter_t4tek" model="ir.ui.view">
        <field name="name">hr_attendance_view_filter_t4tek</field>
        <field name="model">hr.attendance</field>
        <field name="arch" type="xml">
            <search string="Hr Attendance Search">
                <field name="employee_id"/>
                <field name="department_id" operator="child_of"/>
                <field name="check_in"/>
                <filter string="My Attendances" name="myattendances" domain="[('employee_id.user_id', '=', uid)]" />
                <filter string="My Team" name="myteam" domain="[('employee_id.parent_id.user_id', '=', uid)]"/>
                <separator/>
                <filter string="At Work" name="nocheckout" domain="[('check_out', '=', False)]" />
                <filter string="Errors" name="errors"
                        domain="['|', ('worked_hours', '&gt;=', 16), '&amp;', ('check_out', '=', False), ('check_in', '&lt;=',  (context_today() - datetime.timedelta(days=1)).strftime('%Y-%m-%d'))]"/>
                <filter string="Automatically Checked-Out" name="auto_check"
                        domain="[('out_mode', '=', 'auto_check_out')]"/>
                <separator/>
                <filter string="Date" name="check_in_filter" date="check_in"/>
                <separator/>
                <filter
                    string="Active Employees"
                    name="activeemployees"
                    domain="[('employee_id.active', '=', True)]"/>
                <filter
                    string="Archived Employees"
                    name="archivedemployees"
                    domain="[('employee_id.active', '=', False)]"/>
                <separator invisible="1"/>
                <filter string="Last 3 Months" invisible="1" name="last_three_months" domain="[(
                    'check_in','&gt;=', (
                        context_today() + datetime.timedelta(days=-90)
                        )
                    )]"/>
                <group>
                    <filter string="Employee" name="employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Departement" name="departement" context="{'group_by': 'department_id'}"/>
                    <filter string="Manager" name="manager" context="{'group_by': 'manager_id'}"/>
                    <filter string="Method" name="groupby_mode_in" context="{'group_by': 'in_mode'}"/>
                    <filter string="Date" name="groupby_name" context="{'group_by': 'check_in:month'}"/>
                </group>
            </search>
        </field>
    </record>

   
    <!-- Action Gọi thẳng Báo cáo từ bảng Attendance gốc -->
    <record id="attendance_report_detail_action" model="ir.actions.act_window">
        <field name="name">Phân tích Báo cáo chấm công</field>
        <field name="res_model">hr.attendance</field>
        <field name="view_mode">list,pivot,graph,kanban</field>
        <field name="search_view_id" ref="sem_attendance.hr_attendance_view_filter_t4tek"/>
        <!-- Không ép các lệnh search_default_group_by nữa để giống hệt Odoo gốc -->
        <field name="context">{
            "search_default_activeemployees": 1,
            "search_default_employee": 2,
        }</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('sem_attendance.hr_attendance_view_list_report_t4tek')}),
            (0, 0, {'view_mode': 'pivot', 'view_id': ref('sem_attendance.hr_attendance_view_pivot_t4tek')}),
            (0, 0, {'view_mode': 'graph', 'view_id': ref('sem_attendance.hr_attendance_view_graph_t4tek')}),
            (0, 0, {'view_mode': 'kanban', 'view_id': ref('sem_attendance.view_hr_attendance_kanban_t4tek')}),
        ]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_empty_folder">
                Báo cáo phân tích chấm công trực tiếp từ Hệ thống
            </p>
            <p>
                Dữ liệu được phân tích theo thời gian thực từ phần Điểm danh.
            </p>
        </field>
    </record>
</odoo>
